# Copy this file to .env (or set these in your deployment environment).
# Never commit the actual .env file — it contains secrets.
# Canonical reference (descriptions, sources, ownership): docs/ENV_VARS.md

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname?ssl=require

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>

# Used by FastAPI to validate Supabase JWTs (HS256 fallback).
SUPABASE_JWT_SECRET=<supabase-jwt-secret>

# ── Admin / invite management ─────────────────────────────────────────────
# WARNING: The service role key bypasses Row Level Security and has full DB
# access. It must NEVER be committed, logged, or exposed publicly.
# Obtain it from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# ── Email / Invite ─────────────────────────────────────────────────────────
# Provider for outbound invite emails. Only "resend" is implemented.
INVITE_EMAIL_PROVIDER=resend
# Resend API key — obtain from resend.com dashboard.
RESEND_API_KEY=<resend-api-key>
# From address used in invite emails. Must be a verified sender in Resend.
ADMIN_EMAIL_FROM=team@ubcpsych.com
# Base URL for invite acceptance links embedded in emails.
SITE_URL=https://ubcpsych.com

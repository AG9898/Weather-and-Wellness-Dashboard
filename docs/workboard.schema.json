{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "./workboard.schema.json",
  "title": "Weather-and-Wellness-Dashboard workboard schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tasks"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/task"
      }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "description",
        "status",
        "priority",
        "group_id",
        "depends_on",
        "blocked_by",
        "acceptance_criteria",
        "docs",
        "files",
        "commands"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["implementation", "manual", "design", "infra", "docs", "research"]
        },
        "estimate": {
          "type": "string",
          "enum": ["XS", "S", "M", "L", "XL"]
        },
        "notes": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": ["todo", "in_progress", "done", "blocked"]
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "group_id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_-]*$"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_-]*$"
          },
          "uniqueItems": true
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "docs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
